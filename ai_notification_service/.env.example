# ============================================================
# ProactiveCare – Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Application ---
APP_NAME=ProactiveCare AI Notification Service
APP_VERSION=1.0.0
APP_ENV=development
APP_PORT=8001
APP_HOST=0.0.0.0

# --- Google Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- Twilio (SMS & WhatsApp) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@hospital.com
SMTP_FROM_NAME=ProactiveCare Hospital

# --- Backend Integration ---
BACKEND_BASE_URL=http://localhost:8000
BACKEND_WEBHOOK_URL=http://localhost:8000/api/v1/notification-status

# --- Logging ---
LOG_LEVEL=INFO
